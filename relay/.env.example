# Cursor LLM 中转服务配置（部署在能直连 Cursor 的服务器上）
# 复制为 .env 后填写真实值：  cp .env.example .env

# 鉴权 token：强随机串，须与 244 端 job-hunter 的 cursor_relay_token 完全一致
# 生成方式：  openssl rand -hex 32
RELAY_TOKEN=

# Cursor API Key（与 244 端原来用的同一把即可）
CURSOR_API_KEY=

# 可选：默认模型（请求 model 为空/auto 时用），不填则 claude-sonnet-4-5。
# 注意：composer-2.5 在部分账号的 SDK 本地 agent 下会报 error，不建议作默认。
RELAY_DEFAULT_MODEL=claude-sonnet-4-5

# 可选：监听端口（默认 443；阿里云轻量防火墙已放行 443）
RELAY_PORT=443
