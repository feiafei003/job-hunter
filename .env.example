# 大模型后端：cursor（用 Cursor SDK）或 deepseek
LLM_PROVIDER=cursor

# Cursor SDK 配置（LLM_PROVIDER=cursor 时使用）
# API key 在 https://cursor.com/dashboard/integrations 获取
CURSOR_API_KEY=
# 模型 ID；auto 让服务端自动选择（最稳）。可选 composer-2.5 等，但需账号支持
CURSOR_MODEL=auto

# DeepSeek API 配置（LLM_PROVIDER=deepseek 时使用，OpenAI 兼容接口）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# 是否让 DeepSeek 请求走系统代理。默认 false=绕过代理直连。
# 若公司代理拦截 api.deepseek.com（返回 403），保持 false。
DEEPSEEK_USE_PROXY=false

# 数据与浏览器会话存储目录（默认当前目录下 ./data）
DATA_DIR=./data

# 抓取拟人化节奏（秒）。每个动作之间的随机延迟范围
SCRAPE_MIN_DELAY=2.0
SCRAPE_MAX_DELAY=5.0

# 每个搜索配置单次最多抓取的职位数（控制频率、降低风控）
MAX_JOBS_PER_RUN=20

# 浏览器是否以可见(headed)模式抓取。登录始终为可见模式。
# 抓取时建议 false（无头），如遇风控可改为 true
SCRAPE_HEADLESS=true

# 本机你的技能/简历画像（供 AI 做匹配分析，可留空，也可在网页里填）
CANDIDATE_PROFILE=
